{
  "name": "domain-tool",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "infra:up": "node scripts/docker-cli.mjs compose up -d postgres redis",
    "infra:up:storage": "node scripts/docker-cli.mjs compose --profile storage up -d",
    "infra:down": "node scripts/docker-cli.mjs compose down",
    "db:migrate:local": "pnpm --filter=@repo/database db:migrate:local",
    "readiness:check": "pnpm --filter=@repo/core readiness:check",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "pg": "^8.16.3",
    "prettier": "^3.2.5",
    "turbo": "^2.3.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  },
  "license": "AGPL-3.0"
}
