{
    "name": "@repo/database",
    "version": "0.0.0",
    "private": true,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
        "db:migrate:local": "node scripts/migrate-local.mjs",
        "clean": "rm -rf dist node_modules"
    },
    "dependencies": {
        "better-auth": "^1.5.4",
        "drizzle-orm": "^0.45.1",
        "pg": "^8.20.0"
    },
    "devDependencies": {
        "@repo/tsconfig": "workspace:*",
        "@types/pg": "^8.18.0",
        "drizzle-kit": "^0.31.9",
        "typescript": "^5.5.0"
    }
}
