{
    "name": "@repo/web",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "node --experimental-strip-types ../../packages/core/scripts/startup-check.mjs web && node ../../packages/core/scripts/run-with-env.mjs pnpm exec next dev --turbopack",
        "build": "node ../../packages/core/scripts/run-with-env.mjs pnpm exec next build --webpack",
        "start": "node --experimental-strip-types ../../packages/core/scripts/startup-check.mjs web && node ../../packages/core/scripts/run-with-env.mjs pnpm exec next start",
        "lint": "eslint .",
        "clean": "rm -rf .next node_modules"
    },
    "dependencies": {
        "next": "^16.1.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "@tanstack/react-query": "^5.75.0",
