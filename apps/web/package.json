        "drizzle-orm": "^0.45.1",
        "server-only": "^0.0.1",
        "zod": "^3.24.0",
        "@repo/ui": "workspace:*",
        "@repo/database": "workspace:*",
        "@repo/core": "workspace:*"
    },
    "devDependencies": {
        "@repo/tsconfig": "workspace:*",
        "@repo/eslint-config": "workspace:*",
        "@types/node": "^22.15.0",
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "autoprefixer": "^10.4.21",
        "postcss": "^8.5.3",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.8.0",
        "eslint": "^9.25.0"
    }
